@page
@model MyPortfolio.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

<header class="page-hero">
    <h1>About Me</h1>
    <p>Get to know the person behind the code.</p>
</header>

<section class="section">
    <div class="section-inner">
        <div class="about-grid">
            <div style="text-align:center;">
                <div class="about-avatar">👨‍💻</div>
                <div style="margin-top:24px;">
                    <div class="skill-tags" style="justify-content:center;">
                        <span class="skill-tag">Available for hire</span>
                        <span class="skill-tag">Open to collaborate</span>
                    </div>
                </div>
            </div>
            <div class="about-text">
                <h2>Hello, I'm a Full-Stack Developer 👋</h2>
                <p>I'm a passionate web developer with expertise in ASP.NET Core, C#, and modern web technologies. I love building clean, functional, and visually appealing applications.</p>
                <p>With a strong foundation in both front-end design and back-end logic, I create complete solutions from database design to deployment.</p>
                <p>When I'm not coding, I enjoy exploring new technologies and contributing to open-source projects.</p>
                <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:24px;">
                    <a href="/Portfolio" class="btn-primary">View Work</a>
                    <a href="/Resume" class="btn-secondary">Download CV</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section" style="background:var(--dark2); padding-top:60px; padding-bottom:60px;">
    <div class="section-inner">
        <div class="section-header">
            <div class="section-tag">Skills</div>
            <h2 class="section-title">My Expertise</h2>
        </div>
        <div class="card-grid">
            <div class="card">
                <div class="card-icon">🖥️</div>
                <h3>Frontend</h3>
                <p>HTML5, CSS3, JavaScript, Responsive Design, UI/UX principles</p>
            </div>
            <div class="card">
                <div class="card-icon">⚙️</div>
                <h3>Backend</h3>
                <p>ASP.NET Core, C#, Razor Pages, RESTful APIs, Session Management</p>
            </div>
            <div class="card">
                <div class="card-icon">🗃️</div>
                <h3>Database</h3>
                <p>MySQL, Entity Framework Core, Database design & optimization</p>
            </div>
        </div>
    </div>
</section>
