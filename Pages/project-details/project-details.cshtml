@page
@{
    ViewData["Title"] = "Project Details";
}

<div class="mt-3">
    <a asp-page="/Portfolio" 
       style="display: inline-block; margin-top: 15px; color: #6c63ff; font-weight: bold; text-decoration: none;">
        ← Back to Portfolio
    </a>
</div>

<div class="container mt-5">
    <div class="project-header mb-4">
        <h1>E-Commerce Platform Details</h1>
        <p class="text-muted">Full-stack development project</p>
    </div>

    <div class="row">
        <div class="col-md-8">
            <h3>Project Overview</h3>
            <p>
                This high-performance e-commerce solution was developed as part of my Full-stack learning journey.
                It features a robust backend using <strong>ASP.NET Core</strong> and <strong>MySQL</strong>.
            </p>

            <h3>Key Features</h3>
            <ul>
                <li>User Authentication and Authorization.</li>
                <li>Shopping Cart functionality with persistent storage.</li>
                <li>Secure Checkout process.</li>
                <li>Admin Dashboard for product management.</li>
            </ul>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h5>Tech Stack</h5>
                <hr>
                <p><strong>Backend:</strong> ASP.NET Core 9.0</p>
                <p><strong>Database:</strong> MySQL</p>
                <p><strong>Language:</strong> C#</p>
                <p><strong>Frontend:</strong> Razor Pages, CSS3, HTML5</p>
            </div>

        </div>
    </div>
</div>