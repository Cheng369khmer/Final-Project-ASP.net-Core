@page
@model MyPortfolio.Pages.ResumeModel
@{
    ViewData["Title"] = "Resume";
}

<link rel="stylesheet" href="~/css/style.css" />

<section class="section" style="padding-top: 20px;"> <!-- បន្ថយគម្លាតពីលើគេបង្អស់ -->
    <div class="section-inner" style="max-width: 100%; padding: 0;">
        <div class="resume-container">

            <div class="resume-section">
                <h3>👤 Personal Details</h3>
                <div class="personal-details-wrapper">
                    <div class="resume-item" style="border-left: none; padding-left: 0;">
                        <!-- លុប ::before និង border សម្រាប់ផ្នែកនេះ ដើម្បីកុំឱ្យមានបន្ទាត់ -->
                        <p><strong>Full Name:</strong> Sokhom ThangCheng</p>
                        <p><strong>Date of Birth:</strong> June 05, 2002</p>
                        <p><strong>Place of Birth:</strong> Prey Veng Province</p>
                        <p><strong>Current Role:</strong> IT Student & IT Support Professional</p>
                    </div>

                    <!-- ផ្នែករូបថត -->
                    <div class="profile-photo-container">
                        <img src="/images/avatars/mr.cheng.jpg" alt="Sokhom ThangCheng" class="profile-photo" />
                    </div>
                </div>
            </div>

            <div class="resume-section">
                <h3>💼 Work Experience</h3>

                <div class="resume-item">
                    <div class="resume-item-header">
                        <h4>IT Support Staff — Chenla University</h4>
                        <span class="resume-date">2026 – Present</span>
                    </div>
                    <p>Providing technical support and maintaining IT systems within the university environment.</p>
                </div>

                <div class="resume-item">
                    <div class="resume-item-header">
                        <h4>Volunteer — TYDA (Samdech Hun Many's Volunteer Doctors)</h4>
                        <span class="resume-date">2021 – 2022</span>
                    </div>
                    <p>Actively participated in the National COVID-19 Vaccination Campaign across the country and within
                        the Prek Pnov district.</p>
                    </div>

                    <div class="resume-item">
                        <div class="resume-item-header">
                            <h4>Sales & Service Representative</h4>
                            <span class="resume-date">2019 – 2021</span>
                        </div>
                        <p>Gained valuable customer service experience working in health food sales and at AEON Mall 1.</p>
                    </div>
                </div>

                <div class="resume-section">
                    <h3>🎓 Education</h3>

                    <div class="resume-item">
                        <div class="resume-item-header">
                            <h4>Bachelor of Information Technology (3rd Year)</h4>
                            <span class="resume-date">2025 – Present</span>
                        </div>
                        <p>Currently pursuing a degree in the Faculty of Science and Technology at Chenla University.</p>
                    </div>

                    <div class="resume-item">
                        <div class="resume-item-header">
                            <h4>High School Diploma</h4>
                            <span class="resume-date">2020</span>
                        </div>
                        <p>Successfully completed the National High School Examination in Prey Veng Province.</p>
                    </div>

                    <div class="resume-item">
                        <div class="resume-item-header">
                            <h4>Lower Secondary School Certificate</h4>
                            <span class="resume-date">2017</span>
                        </div>
                        <p>Graduated from Chan Kriskna High School.</p>
                    </div>
                </div>

                <div class="resume-section">
                    <h3>🛠️ Technical Skills</h3>
                    <div style="display: flex; flex-direction: column; gap: 16px;">

                        <div class="skill-category">
                            <span style="color: var(--text-muted); font-size: 0.85rem; font-weight: bold;">Software &
                                Design</span>
                                <div class="skill-tags" style="margin-top: 8px;">
                                    <span class="skill-tag">MS Word</span>
                                    <span class="skill-tag">MS Excel</span>
                                    <span class="skill-tag">PowerPoint</span>
                                    <span class="skill-tag">Figma</span>
                                </div>
                            </div>

                            <div class="skill-category">
                                <span style="color: var(--text-muted); font-size: 0.85rem; font-weight: bold;">Development &
                                    Infrastructure</span>
                                    <div class="skill-tags" style="margin-top: 8px;">
                                        <span class="skill-tag">ASP.NET Core</span>
                                        <span class="skill-tag">Full-stack Development</span>
                                        <span class="skill-tag">IT Support</span>
                                        <span class="skill-tag">Network Administration</span>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <div class="resume-section">
                            <h3>🌐 Languages</h3>
                            <div class="skill-tags" style="margin-top: 8px;">
                                <span class="skill-tag">Khmer (Native)</span>
                                <span class="skill-tag">English (Intermediate)</span>
                                <span class="skill-tag">Japanese (Basic)</span>
                            </div>
                        </div>

                    </div>
                </div>
            </section>