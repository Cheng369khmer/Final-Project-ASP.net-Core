@page
@{
    ViewData["Title"] = "System CLU Details";
}

<link rel="stylesheet" href="~/css/style.css" />

<div class="page-hero">
    <span class="tag">🌐 CHENLA UNIVERSITY / IT</span>
    <h1>System CLU Details</h1>
    <p>Explore computer network systems and the configuration of Cisco Routers and Switches</p>
</div>

<section class="section">
    <div class="section-inner">
        <div class="course-container">

            <div class="course-card">
                <h2 style="color: var(--primary-color); margin-top: 0;">About This Course</h2>
                <p style="color: var(--text-muted); line-height: 1.8;">
                    This course is specially designed for beginners who want to explore the fundamentals of networking
                    systems.
                    You will gain both theoretical knowledge and hands-on practice using Cisco Packet Tracer
                    to prepare yourself to become an excellent Network Engineer in the future.
                </p>

                <h3 style="margin-top: 2.5rem; color: var(--text-main);">What You Will Learn:</h3>
                <ul class="feature-list">
                    <li>✅ Deep understanding of the OSI Model and TCP/IP Model</li>
                    <li>✅ How to configure IP Addresses (IPv4 & IPv6) and perform Subnetting</li>
                    <li>✅ Basic configuration on Cisco Routers and Switches</li>
                    <li>✅ Explore VLANs and Routing Protocols (OSPF, EIGRP)</li>
                </ul>
            </div>

            <div class="course-card sidebar-card">
                <h3
                    style="margin-top: 0; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; color: var(--text-main);">
                    General Information
                </h3>

                <div class="info-row">
                    <span style="color: var(--text-muted);">Level:</span>
                    <span style="font-weight: bold; color: var(--text-main);"> Beginner and Advanced</span>
                </div>
                <div class="info-row">
                    <span style="color: var(--text-muted);">Duration:</span>
                    <span style="font-weight: bold; color: var(--text-main);"> 4 Years</span>
                </div>
                <div class="info-row">
                    <span style="color: var(--text-muted);">Language:</span>
                    <span style="font-weight: bold; color: var(--text-main);">Khmer and English</span>
                </div>

                <div style="margin-top: 2rem;">
                    <a href="https://iquiz.clu.asia/" target="_blank" class="btn-active"
                       style="display: block; margin-bottom: 1rem; width: 100%; padding: 0.8rem; border-radius: 8px; text-align: center; color: white; text-decoration: none; font-weight: 600;">
                        Enroll here 🚀
                    </a>

                    <a href="/Portfolio" class="btn-active btn-outline">🔙 Go Back</a>
                </div>
            </div>

        </div>
    </div>
</section>