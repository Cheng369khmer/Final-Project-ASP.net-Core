@page
@{
    ViewData["Title"] = "System CLU Details";
}

<link rel="stylesheet" href="~/css/style.css" />

<div class="page-hero">
    <span class="tag">🌐 Networking / IT</span>
    <h1>System CLU Details</h1>
    <p>ស្វែងយល់ពីប្រព័ន្ធបណ្តាញកុំព្យូទ័រ និងការកំណត់រចនាសម្ព័ន្ធឧបករណ៍ Cisco Routers និង Switches</p>
</div>

<section class="section">
    <div class="section-inner">
        <div class="course-container">

            <div class="course-card">
                <h2 style="color: var(--primary-color); margin-top: 0;">អំពីវគ្គសិក្សានេះ</h2>
                <p style="color: var(--text-muted); line-height: 1.8;">
                    វគ្គសិក្សានេះត្រូវបានរៀបចំឡើងយ៉ាងពិសេសសម្រាប់អ្នកដែលទើបតែចាប់ផ្តើម
                    និងចង់ស្វែងយល់ពីមូលដ្ឋានគ្រឹះនៃប្រព័ន្ធ Network។
                    អ្នកនឹងទទួលបានចំណេះដឹងទាំងទ្រឹស្តី និងការអនុវត្តផ្ទាល់នៅលើកម្មវិធី Cisco Packet Tracer
                    ដើម្បីត្រៀមខ្លួនក្លាយជា Network Engineer ដ៏ពូកែម្នាក់នាពេលអនាគត។
                </p>

                <h3 style="margin-top: 2.5rem; color: var(--text-main);">អ្វីដែលអ្នកនឹងទទួលបាន៖</h3>
                <ul class="feature-list">
                    <li>✅ យល់ដឹងស៊ីជម្រៅពី OSI Model និង TCP/IP Model</li>
                    <li>✅ ចេះរៀបចំ IP Address (IPv4 & IPv6) និងការធ្វើ Subnetting</li>
                    <li>✅ ការកំណត់រចនាសម្ព័ន្ធមូលដ្ឋានលើ Cisco Router និង Switch</li>
                    <li>✅ ស្វែងយល់ពី VLANs និង Routing Protocols (OSPF, EIGRP)</li>
                </ul>
            </div>

            <div class="course-card sidebar-card">
                <h3
                    style="margin-top: 0; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; color: var(--text-main);">
                    ព័ត៌មានទូទៅ</h3>

                    <div class="info-row">
                        <span style="color: var(--text-muted);">កម្រិត:</span>
                        <span style="font-weight: bold; color: var(--text-main);">មូលដ្ឋាន (Beginner)</span>
                    </div>
                    <div class="info-row">
                        <span style="color: var(--text-muted);">រយៈពេល:</span>
                        <span style="font-weight: bold; color: var(--text-main);">៣ ខែ</span>
                    </div>
                    <div class="info-row">
                        <span style="color: var(--text-muted);">ភាសា:</span>
                        <span style="font-weight: bold; color: var(--text-main);">ខ្មែរ</span>
                    </div>

                    <div style="margin-top: 2rem;">
                        <a href="https://iquiz.clu.asia/" target="_blank" class="btn-active"
                           style="display: block; margin-bottom: 1rem; width: 100%; padding: 0.8rem; border-radius: 8px; text-align: center; color: white; text-decoration: none; font-weight: 600;">
                            ចុះឈ្មោះរៀននៅទីនេះ 🚀
                        </a>

                        <a href="/Portfolio" class="btn-active btn-outline">🔙 ត្រលប់ក្រោយ</a>
                    </div>
                </div>

            </div>
        </div>
    </section>