@page
@model MyPortfolio.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<style>
    /* បន្ថែម CSS នេះដើម្បីរៀបទីតាំង icon ភ្នែកឲ្យនៅខាងស្ដាំក្នុងប្រអប់ password */
    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    
    .password-wrapper input {
        width: 100%;
        padding-right: 40px; /* ទុកចន្លោះសម្រាប់ icon */
    }
    
    .toggle-password-btn {
        position: absolute;
        right: 10px;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--text-muted, #888); /* អ្នកអាចប្ដូរពណ៌តាមការចង់បាន */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }
    
    .toggle-password-btn:focus {
        outline: none;
    }
</style>

<div class="auth-page">
    <div class="auth-card">
        <h2>🔐 Welcome Back</h2>
        <p class="auth-sub">Sign in to your account</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.InfoMessage))
        {
            <div class="alert alert-info">@Model.InfoMessage</div>
        }

        <form method="post">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="Email" placeholder="you@example.com" required autocomplete="email" />
            </div>
            
            <div class="form-group">
                <label>Password</label>
                <!-- បានបន្ថែម Wrapper ទីនេះ -->
                <div class="password-wrapper">
                    <input type="password" id="passwordInput" name="Password" placeholder="Enter your password" required />
                    
                    <button type="button" id="togglePasswordBtn" class="toggle-password-btn" aria-label="Toggle password visibility">
                        <!-- SVG រូបភ្នែក -->
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </button>
                </div>
            </div>
            
            <button type="submit" class="btn-full">Login</button>
        </form>

        <div class="auth-footer">
            Don't have an account? <a href="/Register">Register here</a>
        </div>
        <div class="auth-footer" style="margin-top:8px;">
            <small style="color:var(--text-muted);"> Admin : admincheng@portfolio.com / admin123 </small>
            <small style="color:var(--text-muted);"> — User : sopheaclu@gmail.com / user123</small>
        </div>
    </div>
</div>

<!-- បន្ថែម JavaScript នៅផ្នែកខាងក្រោម ដើម្បីដំណើរការការចុច -->
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const togglePasswordBtn = document.getElementById('togglePasswordBtn');
            const passwordInput = document.getElementById('passwordInput');
            const eyeIcon = document.getElementById('eyeIcon');

            togglePasswordBtn.addEventListener('click', function () {
                // ពិនិត្យមើលប្រភេទ input ថាជា password ឬ text រួចធ្វើការផ្លាស់ប្ដូរ
                const isPassword = passwordInput.getAttribute('type') === 'password';
                passwordInput.setAttribute('type', isPassword ? 'text' : 'password');

                // ផ្លាស់ប្ដូររូប icon ភ្នែក (បើកភ្នែក ទៅ បិទភ្នែក)
                if (isPassword) {
                    // រូបភ្នែកមានគំនូសកាត់ (Eye-off)
                    eyeIcon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
                } else {
                    // រូបភ្នែកធម្មតា
                    eyeIcon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
                }
            });
        });
    </script>
}