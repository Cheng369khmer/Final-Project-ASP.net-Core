@page
@model MyPortfolio.Pages.Admin.AddUserModel
@{
    ViewData["Title"] = "Add New User";
    Layout = "_Layout";
}

<div class="admin-layout">
    <aside class="admin-sidebar">
        <h3>Admin Panel</h3>
        <a href="/Admin/Dashboard" class="admin-nav-link">📊 Dashboard</a>
        <a href="/Admin/Users" class="admin-nav-link active">👥 Manage Users</a>
        <a href="/" class="admin-nav-link">🌐 View Site</a>
        <a href="/Logout" class="admin-nav-link" style="color:var(--accent);">🚪 Logout</a>
    </aside>

    <main class="admin-main">
        <h2>Add New User</h2>
        <p class="subtitle">Fill in the details below to create a new account</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" style="background: rgba(239,68,68,0.15); color: #fca5a5; padding: 15px; border-radius: 8px; border: 1px solid rgba(239,68,68,0.3); margin-bottom: 20px;">
                @Model.ErrorMessage
            </div>
        }

        <div style="background: rgba(255,255,255,0.05); padding: 25px; border-radius: 10px; max-width: 600px; border: 1px solid rgba(255,255,255,0.1);">
            <form method="post" style="display: flex; flex-direction: column; gap: 15px;">
                
                <div>
                    <label style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 5px; display: block;">Full Name:</label>
                    <input type="text" asp-for="NewUser.Name" required 
                           style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.2); color: white; outline: none;" placeholder="e.g. Sokhom Cheng" />
                </div>

                <div>
                    <label style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 5px; display: block;">Email Address:</label>
                    <input type="email" asp-for="NewUser.Email" required 
                           style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.2); color: white; outline: none;" placeholder="user@portfolio.com" />
                </div>

                <div>
                    <label style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 5px; display: block;">Password:</label>
                    <input type="password" asp-for="NewUser.Password" required 
                           style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.2); color: white; outline: none;" placeholder="Create a strong password" />
                </div>

                <div style="display: flex; gap: 20px;">
                    <div style="flex: 1;">
                        <label style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 5px; display: block;">Gender:</label>
                        <select asp-for="NewUser.Gender" 
                                style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.2); color: white; outline: none;">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>

                    <div style="flex: 1;">
                        <label style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 5px; display: block;">Role:</label>
                        <select asp-for="NewUser.Role" 
                                style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.2); color: white; outline: none;">
                            <option value="User">User</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 5px; display: block;">Remark / Position:</label>
                    <textarea asp-for="NewUser.Remark" rows="3" 
                              style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.2); color: white; outline: none; resize: vertical;" placeholder="e.g. Web Developer"></textarea>
                </div>

                <div style="display: flex; gap: 10px; margin-top: 15px;">
                    <button type="submit" 
                            style="background: #10b981; color: white; padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.3s;">
                        ✔ Save User
                    </button>
                    <a href="/Admin/Users" 
                       style="background: #4b5563; color: white; padding: 10px 20px; text-decoration: none; border-radius: 6px; font-weight: bold; transition: 0.3s;">
                        ✖ Cancel
                    </a>
                    </button>
                    <a href="/Admin/Users" 
                       style="background: #4b5563; color: white; padding: 10px 20px; text-decoration: none; border-radius: 6px; font-weight: bold; transition: 0.3s;">
                        <-- Back to List -->
                    </a>
                </div>
            </form>
        </div>
    </main>
</div>