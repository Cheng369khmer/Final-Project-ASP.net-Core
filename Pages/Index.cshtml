@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="hero">
    <div class="hero-bg-grid"></div>
    <div class="hero-content">
        <div class="hero-badge">👋 Welcome to My Portfolio</div>
        <h1>Hello ! <span>CHENG</span><br/>Developer Network</h1>
        <p>"Full-stack Developer | IT Support at Chenla University
        Bridging technical support and creative development to build impactful systems."</p>
        <div class="hero-btns">
            <a href="/Portfolio" class="btn-primary">View My Work</a>
            <a href="/Contact" class="btn-secondary">Get In Touch</a>
        </div>
    </div>
</section>

<!-- SERVICES -->
<section class="section" style="background: var(--dark2);">
    <div class="section-inner">
        <div class="section-header">
            <div class="section-tag">What I Do</div>
            <h2 class="section-title">My Services</h2>
            <p class="section-desc">I deliver end-to-end solutions from design to deployment.</p>
        </div>
        <div class="card-grid">
            <div class="card">
                <div class="card-icon">🎨</div>
                <h3>UI/UX Design</h3>
                <p>Creating beautiful, intuitive interfaces that users love — from wireframes to polished designs.</p>
            </div>
            <div class="card">
                <div class="card-icon">💻</div>
                <h3>Web Development</h3>
                <p>Building fast, scalable web apps with ASP.NET Core, Razor Pages, HTML/CSS and JavaScript.</p>
            </div>
            <div class="card">
                <div class="card-icon">🗄️</div>
                <h3>Database Design</h3>
                <p>Designing and optimizing MySQL databases for performance and reliability.</p>
            </div>
            <div class="card">
                <div class="card-icon">🔐</div>
                <h3>Authentication Systems</h3>
                <p>Secure login, role-based access control, and session management built the right way.</p>
            </div>
            <div class="card">
                <div class="card-icon">📱</div>
                <h3>Responsive Design</h3>
                <p>Every project looks great on every device — desktop, tablet, and mobile.</p>
            </div>
            <div class="card">
                <div class="card-icon">🚀</div>
                <h3>Deployment</h3>
                <p>Taking your project from local development to live production with confidence.</p>
            </div>
        </div>
    </div>
</section>

<!-- TECH STACK -->
<section class="section">
    <div class="section-inner">
        <div class="section-header">
            <div class="section-tag">Technologies</div>
            <h2 class="section-title">Tech Stack</h2>
        </div>
        <div style="text-align:center;">
            <div class="skill-tags" style="justify-content:center; gap:12px;">
                <span class="skill-tag">ASP.NET Core</span>
                <span class="skill-tag">C#</span>
                <span class="skill-tag">Razor Pages</span>
                <span class="skill-tag">Entity Framework</span>
                <span class="skill-tag">MySQL</span>
                <span class="skill-tag">HTML5</span>
                <span class="skill-tag">CSS3</span>
                <span class="skill-tag">JavaScript</span>
                <span class="skill-tag">XAMPP</span>
                <span class="skill-tag">Git</span>
                <span class="skill-tag">VS Code</span>
            </div>
        </div>
    </div>
</section>


